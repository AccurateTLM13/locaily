{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pilot-hardware-profile",
  "title": "Pilot Hardware Profile",
  "description": "Describes a single device participating in the multi-device pilot (M9).",
  "type": "object",
  "required": [
    "deviceName",
    "os",
    "cpu",
    "ram",
    "vram",
    "runtimeProvider",
    "availableModels",
    "advertisedCapabilities",
    "networkAddress"
  ],
  "additionalProperties": false,
  "properties": {
    "deviceName": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name for this device (e.g. 'desktop-gpu', 'laptop-arm')."
    },
    "os": {
      "type": "string",
      "minLength": 1,
      "description": "Operating system and version (e.g. 'Windows 11 23H2', 'Ubuntu 24.04')."
    },
    "cpu": {
      "type": "string",
      "minLength": 1,
      "description": "CPU model and core count (e.g. 'AMD Ryzen 9 7950X 16-core')."
    },
    "ram": {
      "type": "object",
      "required": ["gb"],
      "additionalProperties": false,
      "properties": {
        "gb": {
          "type": "number",
          "minimum": 0,
          "description": "Total system RAM in gigabytes."
        },
        "type": {
          "type": "string",
          "description": "Memory type (e.g. 'DDR5', 'LPDDR5')."
        }
      }
    },
    "vram": {
      "type": "object",
      "required": ["gb"],
      "additionalProperties": false,
      "properties": {
        "gb": {
          "type": "number",
          "minimum": 0,
          "description": "GPU VRAM in gigabytes. Use 0 if no discrete GPU."
        },
        "gpu": {
          "type": "string",
          "description": "GPU model (e.g. 'NVIDIA RTX 4090', 'Apple M3 Max')."
        }
      }
    },
    "runtimeProvider": {
      "type": "string",
      "minLength": 1,
      "description": "Runtime provider available on this device (e.g. 'ollama', 'mock')."
    },
    "availableModels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0,
      "description": "List of model names available on this device (e.g. ['llama3.2', 'lfm2.5-1.2b-thinking'])."
    },
    "advertisedCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0,
      "description": "List of capability roles this device can serve as a relay node for (e.g. ['default_worker', 'priority_helper'])."
    },
    "networkAddress": {
      "type": "string",
      "minLength": 1,
      "description": "Base URL of the Local Brain on this device (e.g. 'http://192.168.1.50:31313')."
    }
  }
}
