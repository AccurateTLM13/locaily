{
  "name": "locaily",
  "version": "1.0.0",
  "description": "Local-first AI coordination stack with Benchmark Lab evaluation subsystem",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "scripts": {
    "start": "node companion/server.js",
    "test:contract": "node scripts/contract-test.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:benchmark": "node scripts/benchmark-lab-schema-test.js && node scripts/benchmark-lab-run-test.js && node scripts/benchmark-lab-mode-comparison-test.js",
    "validate": "node scripts/benchmark-lab-schema-test.js && node scripts/benchmark-lab-run-test.js && node scripts/benchmark-lab-mode-comparison-test.js && node scripts/contract-test.js",
    "tool-eval:run": "node benchmark-lab/engine/cli/tool-eval-run.js",
    "tool-eval:test": "node scripts/benchmark-lab-tool-eval-test.js",
    "benchmark:probe": "node benchmark-lab/engine/cli/benchmark-probe.js",
    "benchmark:diagnose": "node benchmark-lab/engine/cli/tc65-diagnose.js",
    "benchmark:hybrid": "node benchmark-lab/engine/cli/benchmark-hybrid.js",
    "benchmark:run": "node benchmark-lab/engine/cli/benchmark-run.js",
    "benchmark:review": "node benchmark-lab/engine/cli/benchmark-review.js",
    "benchmark:promote": "node benchmark-lab/engine/cli/benchmark-promote.js",
    "benchmark:compare": "node benchmark-lab/engine/cli/benchmark-compare.js",
    "benchmark:matrix": "node benchmark-lab/engine/cli/benchmark-matrix.js",
    "model-card:generate": "node benchmark-lab/engine/cli/model-card-generate.js",
    "qualification:generate": "node benchmark-lab/engine/cli/qualification-generate.js",
    "report:generate": "node benchmark-lab/engine/cli/report-generate.js",
    "checksum:verify": "node benchmark-lab/engine/cli/checksum-verify.js",
    "benchmark:status-smoke": "node scripts/benchmark-status-smoke-test.js",
    "benchmark:test": "node scripts/benchmark-lab-schema-test.js && node scripts/benchmark-lab-run-test.js",
    "lighthouse:run": "node scripts/lighthouse-run.js",
    "lighthouse-priority:run": "node benchmark-lab/engine/cli/lighthouse-priority-run.js",
    "lighthouse-priority:test": "node scripts/benchmark-lighthouse-priority-test.js",
    "quality-gate:lighthouse": "node scripts/lighthouse-human-gate.js",
    "lighthouse:handoff": "node scripts/lighthouse-handoff-operator.js",
    "audit:a11y": "node scripts/audit-run.js --track website_audit.accessibility_deep",
    "audit:seo": "node scripts/audit-run.js --track website_audit.seo_audit",
    "audit:budget": "node scripts/audit-run.js --track website_audit.performance_budget",
    "quality-review": "node scripts/quality-review.js",
    "quality-review:test": "node scripts/test-human-review-records.js",
    "quality-gate:website-audit": "node scripts/website-audit-gate.js",
    "audit:dealsniper": "node scripts/audit-run.js --track marketplace.dealsniper",
    "test:dag": "node scripts/test-dag-graph.cjs && node scripts/test-dag-executor.cjs && node scripts/test-run-plan-dag.cjs",
  "test:relay": "node scripts/test-relay-unit.cjs",
  "test:relay:e2e": "node scripts/test-relay-e2e.cjs",
  "test:relay:placement": "node scripts/test-relay-placement.cjs",
  "test:multi-device:e2e": "node scripts/test-multi-device-e2e.cjs",
  "test:memory-v1": "node scripts/test-memory-v1.cjs",
  "test:m4": "node scripts/test-relay-unit.cjs && node scripts/test-memory-v1.cjs && node scripts/test-relay-e2e.cjs",
  "test:m5": "node scripts/test-relay-placement.cjs && node scripts/test-multi-device-e2e.cjs",
    "dag:plan": "curl.exe -s -X POST http://127.0.0.1:31313/tracks/plan -H \"Content-Type: application/json\" -d \"{\\\"request\\\":\\\"$*\\\"}\""
  }
}
