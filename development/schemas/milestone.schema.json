{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/development-milestone.schema.json",
  "title": "Development Milestone",
  "description": "Defines a discrete, deliverable unit of development work. Agent-neutral — used by any coding agent through the development protocol.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "title",
    "status",
    "type",
    "purpose",
    "scope",
    "acceptanceCriteria",
    "createdAt"
  ],
  "properties": {
    "schema": {
      "const": "locaily.development.milestone.v1",
      "description": "Schema identifier."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique milestone identifier (slug format)."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title."
    },
    "status": {
      "type": "string",
      "enum": [
        "idea",
        "planned",
        "ready",
        "active",
        "paused",
        "blocked",
        "validating",
        "ready-for-delivery",
        "delivered",
        "merged",
        "completed",
        "cancelled"
      ],
      "description": "Current milestone status."
    },
    "type": {
      "type": "string",
      "enum": [
        "feature",
        "infrastructure",
        "bugfix",
        "governance",
        "validation",
        "documentation"
      ],
      "description": "Category of work."
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Priority level."
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "description": "Why this milestone exists."
    },
    "problem": {
      "type": "string",
      "description": "What problem this solves."
    },
    "scope": {
      "type": "object",
      "description": "Explicit inclusions and exclusions.",
      "properties": {
        "included": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What is in scope."
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What is explicitly out of scope."
        }
      },
      "required": ["included", "excluded"],
      "additionalProperties": false
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["pending", "satisfied", "waived"] },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["generated-artifact", "test", "generator-test", "validation-record", "manual-verification", "document"] },
                    "reference": { "type": "string", "minLength": 1 },
                    "note": { "type": "string" }
                  },
                  "required": ["type", "reference"],
                  "additionalProperties": false
                }
              },
              "waivedReason": { "type": "string" }
            },
            "required": ["id", "description", "status"],
            "additionalProperties": false
          }
        ]
      },
      "minItems": 1,
      "description": "Conditions that must be met for completion. Strings are unsatisfied; objects carry evidence."
    },
    "validationProfile": {
      "type": ["string", "null"],
      "description": "ID of the validation profile to run before delivery."
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Milestone IDs that must complete first."
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["human-action", "external-dependency", "hardware", "decision-required"] },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "resolutionCondition": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "type", "description", "resolutionCondition"],
        "additionalProperties": false
      },
      "description": "Active blockers."
    },
    "lifecycleRef": {
      "type": ["string", "null"],
      "description": "Reference to the existing objective-lifecycle state (9-state)."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 creation timestamp."
    },
    "startedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO-8601 timestamp when work began."
    },
    "completedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO-8601 timestamp when milestone was completed."
    },
    "mergedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO-8601 timestamp when PR was merged."
    }
  }
}
