{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Transformation Fixture",
  "type": "object",
  "required": ["fixtureId", "input", "expectedVerdict"],
  "additionalProperties": false,
  "properties": {
    "fixtureId": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input": { "type": ["object", "null"] },
    "expectedVerdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "expectedOutput": { "type": "object" },
    "expectedDiagnostics": {
      "type": "object",
      "properties": {
        "missingFields": { "type": "array", "items": { "type": "string" } },
        "typeMismatches": { "type": "array", "items": { "type": "string" } },
        "ignoredSourceFields": { "type": "array", "items": { "type": "string" } },
        "inferredFields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "forbiddenInferredFields": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
