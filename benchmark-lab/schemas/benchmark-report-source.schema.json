{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/benchmark-lab/benchmark-report-source.schema.json",
  "title": "Benchmark Lab Report Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "title",
    "generatedAt",
    "evidenceIds",
    "summaries"
  ],
  "properties": {
    "schemaVersion": {
      "const": "benchmark.report_source.v1"
    },
    "reportId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "evidenceIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "sourceRunId",
          "suiteId",
          "trackId",
          "contractId",
          "caseCount",
          "passed",
          "failed",
          "errors",
          "timeouts",
          "malformed",
          "passRate"
        ],
        "properties": {
          "evidenceId": {
            "type": "string"
          },
          "sourceRunId": {
            "type": "string"
          },
          "suiteId": {
            "type": "string"
          },
          "trackId": {
            "type": "string"
          },
          "contractId": {
            "type": "string"
          },
          "caseCount": {
            "type": "integer",
            "minimum": 0
          },
          "passed": {
            "type": "integer",
            "minimum": 0
          },
          "failed": {
            "type": "integer",
            "minimum": 0
          },
          "errors": {
            "type": "integer",
            "minimum": 0
          },
          "timeouts": {
            "type": "integer",
            "minimum": 0
          },
          "malformed": {
            "type": "integer",
            "minimum": 0
          },
          "passRate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
