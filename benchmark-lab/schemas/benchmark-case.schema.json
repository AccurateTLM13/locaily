{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/benchmark-lab/benchmark-case.schema.json",
  "title": "Benchmark Lab Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "trackId",
    "input",
    "expected"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "trackId": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "enum": [
        "easy",
        "medium",
        "edge",
        "adversarial"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "enum": [
            "extract",
            "summarize",
            "classify",
            "route",
            "unknown"
          ]
        }
      }
    }
  }
}
