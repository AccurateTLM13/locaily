{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/benchmark-lab/benchmark-case.schema.json",
  "title": "Benchmark Lab Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "caseId",
    "trackId",
    "input",
    "expected"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "trackId": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "enum": [
        "easy",
        "medium",
        "edge",
        "adversarial"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "executionPolicy": {
      "type": "string",
      "enum": [
        "NATIVE",
        "DIRECT_RESPONSE",
        "REFUSAL_REQUIRED",
        "STRUCTURED_RESPONSE",
        "DATE_RESOLUTION_REQUIRED",
        "TOOL_THEN_STRUCTURED_RESPONSE",
        "TOOL_THEN_DETERMINISTIC_TRANSFORM"
      ]
    },
    "responseMode": {
      "type": "string",
      "enum": [
        "text",
        "json",
        "json_schema",
        "tool_call",
        "tool_then_text",
        "tool_then_json_schema",
        "deterministic_schema"
      ]
    },
    "supportMode": {
      "type": "string",
      "enum": [
        "native",
        "policy-assisted",
        "runtime-constrained",
        "hybrid-deterministic"
      ]
    },
    "allowedInitialTools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedFollowupTools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "maxTurns": {
      "type": "integer",
      "minimum": 1
    },
    "transformerId": {
      "type": "string",
      "minLength": 1
    },
    "transformerVersion": {
      "type": "string",
      "minLength": 1
    },
    "transformerChecksum": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "enum": [
            "extract",
            "summarize",
            "classify",
            "route",
            "unknown"
          ]
        }
      }
    }
  }
}
