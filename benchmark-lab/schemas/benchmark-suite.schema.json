{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/benchmark-lab/benchmark-suite.schema.json",
  "title": "Benchmark Lab Suite Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "suiteId",
    "name",
    "mode",
    "trackId",
    "contractId",
    "runtime",
    "caseFiles",
    "outputSchema",
    "validators"
  ],
  "properties": {
    "schemaVersion": {
      "const": "benchmark.suite.v1"
    },
    "suiteId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "quick-screen",
        "qualification",
        "regression"
      ]
    },
    "trackId": {
      "type": "string",
      "minLength": 1
    },
    "contractId": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider"
      ],
      "properties": {
        "provider": {
          "enum": [
            "mock",
            "ollama"
          ]
        },
        "responsesPath": {
          "type": "string",
          "minLength": 1
        },
        "modelManifest": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0
        },
        "numPredict": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "caseFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outputSchema": {
      "type": "object"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "json-parse",
          "json-schema",
          "expected-label"
        ]
      }
    }
  }
}
