{
  "type": "object",
  "required": ["recommendations"],
  "properties": {
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["auditId", "action", "priority", "rationale"],
        "properties": {
          "auditId": { "type": "string", "description": "Lighthouse audit ID" },
          "action": { "type": "string", "description": "Specific remediation action" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string", "description": "Why this matters for SEO" },
          "expectedImpact": { "type": "string", "description": "Expected search visibility improvement" }
        }
      }
    }
  }
}
