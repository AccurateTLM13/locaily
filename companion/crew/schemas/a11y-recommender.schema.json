{
  "type": "object",
  "required": ["recommendations"],
  "properties": {
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["auditId", "action", "implementationGuide", "effort"],
        "properties": {
          "auditId": { "type": "string", "description": "Lighthouse audit ID" },
          "action": { "type": "string", "description": "Specific remediation action" },
          "implementationGuide": { "type": "string", "description": "How to implement the fix" },
          "effort": { "type": "string", "enum": ["low", "medium", "high"], "description": "Implementation effort" },
          "affectedElements": { "type": "string", "description": "Types of elements affected" }
        }
      }
    }
  }
}
