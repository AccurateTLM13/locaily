{
  "track_id": "website_audit.lighthouse_handoff",
  "version": "1.0.0",
  "name": "Lighthouse Developer Handoff",
  "description": "First proof track — PageSpeed/Lighthouse report to developer handoff for coding agents.",
  "output_schema": "companion/schemas/lighthouse-handoff.schema.json",
  "verification_step": "verify_output",
  "steps": [
    {
      "id": "extract_metrics",
      "input_map": "$input",
      "executor": {
        "type": "tool",
        "tool": "lighthouse.parse",
        "task": "run"
      }
    },
    {
      "id": "classify_issues",
      "input_map": {
        "opportunities": ["$input.opportunities", []]
      },
      "executor": {
        "type": "tool",
        "tool": "lighthouse.classify_audits",
        "task": "run"
      }
    },
    {
      "id": "prioritize_fixes",
      "input_map": {
        "url": "$input.url",
        "scores": ["$input.scores", {}],
        "rankedOpportunities": ["$artifacts.classify_issues.rankedOpportunities", []],
        "classifiedIssues": ["$artifacts.classify_issues.issues", []]
      },
      "executor": {
        "type": "model",
        "role": "priority_helper",
        "schema": "companion/crew/schemas/prioritize-fixes.schema.json",
        "prompt_template": "prioritize_fixes"
      }
    },
    {
      "id": "validate_priority_fixes",
      "input_map": {
        "opportunities": ["$input.opportunities", []],
        "priorityFixes": ["$artifacts.prioritize_fixes.priorityFixes", []],
        "thinking": ["$artifacts.prioritize_fixes.thinking", ""]
      },
      "executor": {
        "type": "tool",
        "tool": "lighthouse.validate_priority_fixes",
        "task": "run"
      }
    },
    {
      "id": "match_fixes",
      "input_map": {
        "issues": ["$artifacts.classify_issues.issues", []],
        "priorityFixes": ["$artifacts.validate_priority_fixes.priorityFixes", []]
      },
      "executor": {
        "type": "tool",
        "tool": "lighthouse.match_fixes",
        "task": "run"
      }
    },
    {
      "id": "write_developer_tasks",
      "input_map": {
        "url": "$input.url",
        "scores": ["$input.scores", {}],
        "priorityFixes": ["$artifacts.validate_priority_fixes.priorityFixes", "$artifacts.prioritize_fixes.priorityFixes", []],
        "rankedOpportunities": ["$artifacts.classify_issues.rankedOpportunities", []],
        "classifiedIssues": ["$artifacts.classify_issues.issues", []]
      },
      "executor": {
        "type": "model",
        "role": "developer_task_writer",
        "schema": "companion/crew/schemas/developer-task-writer.schema.json",
        "prompt_template": "write_developer_tasks"
      }
    },
    {
      "id": "write_guardrails",
      "input_map": {
        "url": "$input.url",
        "scores": ["$input.scores", {}],
        "priorityFixes": ["$artifacts.validate_priority_fixes.priorityFixes", "$artifacts.prioritize_fixes.priorityFixes", []],
        "developerTasks": ["$artifacts.write_developer_tasks.developerTasks", []],
        "acceptanceCriteria": ["$artifacts.write_developer_tasks.acceptanceCriteria", []],
        "testingChecklist": ["$artifacts.write_developer_tasks.testingChecklist", []],
        "rankedOpportunities": ["$artifacts.classify_issues.rankedOpportunities", []],
        "classifiedIssues": ["$artifacts.classify_issues.issues", []]
      },
      "executor": {
        "type": "model",
        "role": "guardrail_writer",
        "schema": "companion/crew/schemas/guardrail-writer.schema.json",
        "prompt_template": "write_guardrails"
      }
    },
    {
      "id": "write_testing_checklist",
      "input_map": {
        "url": "$input.url",
        "scores": ["$input.scores", {}],
        "priorityFixes": ["$artifacts.validate_priority_fixes.priorityFixes", "$artifacts.prioritize_fixes.priorityFixes", []],
        "developerTasks": ["$artifacts.write_developer_tasks.developerTasks", []],
        "guardrails": ["$artifacts.write_guardrails.implementationGuardrails", []],
        "testingChecklist": ["$artifacts.write_developer_tasks.testingChecklist", []],
        "rankedOpportunities": ["$artifacts.classify_issues.rankedOpportunities", []],
        "classifiedIssues": ["$artifacts.classify_issues.issues", []]
      },
      "executor": {
        "type": "model",
        "role": "testing_checklist_writer",
        "schema": "companion/crew/schemas/testing-checklist-writer.schema.json",
        "prompt_template": "write_testing_checklist"
      }
    },
    {
      "id": "write_handoff",
      "input_map": {
        "url": "$input.url",
        "metrics": ["$artifacts.extract_metrics", {}],
        "classifiedIssues": ["$artifacts.classify_issues", {}],
        "prioritizedFixes": ["$artifacts.validate_priority_fixes", "$artifacts.prioritize_fixes", {}],
        "developerTaskPacket": ["$artifacts.write_developer_tasks", {}],
        "guardrailPacket": ["$artifacts.write_guardrails", {}],
        "testingChecklistPacket": ["$artifacts.write_testing_checklist", {}],
        "matchedFixes": ["$artifacts.match_fixes", {}],
        "opportunities": ["$input.opportunities", []],
        "rankedOpportunities": [
          "$artifacts.classify_issues.rankedOpportunities",
          "$artifacts.extract_metrics.rankedOpportunities",
          []
        ]
      },
      "executor": {
        "type": "tool",
        "tool": "lighthouse-handoff",
        "task": "compose-handoff"
      }
    },
    {
      "id": "verify_output",
      "input_map": {
        "handoff": ["$artifacts.write_handoff", {}]
      },
      "executor": {
        "type": "tool",
        "tool": "lighthouse.verify_handoff",
        "task": "run"
      }
    }
  ]
}
