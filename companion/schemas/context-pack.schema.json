{
  "type": "object",
  "required": [
    "contextPackId",
    "project",
    "task",
    "summary",
    "filesUsed",
    "excerpts",
    "keyDecisions",
    "knownConstraints",
    "openQuestions",
    "warnings",
    "recommendedNextStep"
  ],
  "properties": {
    "contextPackId": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "filesUsed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excerpts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "heading", "text"],
        "properties": {
          "path": { "type": "string" },
          "heading": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "keyDecisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knownConstraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedNextStep": {
      "type": "string"
    },
    "evidenceReferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "vaultPath"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["candidate", "maintainer_run", "event"]
          },
          "vaultPath": { "type": "string" },
          "candidateId": { "type": "string" },
          "runId": { "type": "string" },
          "reviewStatus": { "type": "string" },
          "driftStatus": { "type": "string" },
          "applied": { "type": "boolean" },
          "eventIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "projectSlug": { "type": "string" },
        "preferCanonicalPages": { "type": "boolean" },
        "evidenceCount": { "type": "number" },
        "maintainerPageBudget": { "type": "number" },
        "contextBudget": {
          "type": "object",
          "properties": {
            "limit": { "type": "number" },
            "used": { "type": "number" },
            "filesIncluded": { "type": "number" }
          }
        },
        "staleWarnings": {
          "type": "array",
          "items": { "type": "object" }
        },
        "contradictionWarnings": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  }
}
