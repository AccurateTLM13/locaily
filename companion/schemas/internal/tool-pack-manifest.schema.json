{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.dev/schemas/internal/tool-pack-manifest.schema.json",
  "title": "Tool Pack Manifest",
  "description": "Root shape of tool-packs/*/tool.json validated at load by companion/tools/registry.js loadToolPack().",
  "type": "object",
  "required": ["id", "name", "version", "trust", "tools"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Pack identifier (directory name conventionally matches)"
    },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "trust": {
      "type": "string",
      "enum": ["official", "verified", "community", "experimental", "local_private"]
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Default permissions for tools that omit their own permissions array"
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manifestTool"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "manifestTool": {
      "type": "object",
      "required": ["id", "output_schema"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "model_role": { "type": ["string", "null"] },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tasks": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Defaults to [\"run\"] when omitted at load time"
        },
        "input_schema": {
          "type": "string",
          "minLength": 1,
          "description": "Path relative to pack root"
        },
        "output_schema": {
          "type": "string",
          "minLength": 1,
          "description": "Path relative to pack root"
        }
      },
      "additionalProperties": true
    }
  }
}
