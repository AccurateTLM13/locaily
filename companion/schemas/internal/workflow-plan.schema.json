{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.dev/schemas/internal/workflow-plan.schema.json",
  "title": "Workflow Plan",
  "description": "Structured execution plan produced by run-plan-builder and mutated by run-plan-executor.",
  "type": "object",
  "required": [
    "plan_id",
    "task_id",
    "workflow_id",
    "track_id",
    "status",
    "created_at",
    "input",
    "steps"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Stable plan identifier (plan_*)"
    },
    "task_id": {
      "type": "string",
      "description": "Caller task / run correlation id"
    },
    "workflow_id": {
      "type": "string",
      "description": "Workflow registry id"
    },
    "track_id": {
      "type": "string",
      "description": "Track executed by this plan"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "number",
      "minimum": 0
    },
    "input": {
      "type": "object",
      "description": "Workflow input payload"
    },
    "options": {
      "type": "object",
      "description": "Execution options passed by client"
    },
    "registry": {
      "type": "object",
      "description": "Snapshot of track registry metadata used for planning",
      "properties": {
        "purpose": { "type": "string" },
        "input_type": { "type": "string" },
        "output_type": { "type": "string" },
        "preferred_worker_type": { "type": "string" },
        "fallback_behavior": { "type": "string" }
      },
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/planStep"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "planStep": {
      "type": "object",
      "required": ["step_id", "track_id", "status"],
      "properties": {
        "step_id": { "type": "string" },
        "track_id": { "type": "string" },
        "required_input": {
          "type": "object",
          "description": "Declared input_map or track-input note"
        },
        "expected_output": {
          "type": "object",
          "description": "Schema path or tool output descriptor"
        },
        "worker_type": {
          "oneOf": [
            {
              "type": "object",
              "required": ["type", "tool", "task"],
              "properties": {
                "type": { "const": "tool" },
                "tool": { "type": "string" },
                "task": { "type": "string" }
              },
              "additionalProperties": false
            },
            {
              "type": "object",
              "required": ["type", "role"],
              "properties": {
                "type": { "const": "model" },
                "role": { "type": "string" }
              },
              "additionalProperties": false
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed"]
        },
        "output": {
          "type": "object",
          "description": "Step output after successful execution"
        },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": true
        },
        "duration_ms": { "type": "number", "minimum": 0 },
        "worker_used": {
          "type": "object",
          "description": "Actual worker metadata after execution"
        }
      },
      "additionalProperties": true
    }
  }
}
