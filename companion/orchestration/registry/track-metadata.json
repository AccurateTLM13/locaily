{
  "website_audit.lighthouse_handoff": {
    "purpose": "Convert Lighthouse or PageSpeed data into structured developer handoff notes for coding agents.",
    "input_type": "lighthouse_report",
    "output_type": "developer_handoff",
    "preferred_worker_type": "priority_helper",
    "fallback_behavior": "deterministic_tool_steps_when_runtime_unavailable",
    "validation_expectations": {
      "output_schema": "companion/schemas/lighthouse-handoff.schema.json",
      "verification_step": "verify_output",
      "required_result_sections": [
        "clientSummary",
        "developerSummary",
        "priorityFixes",
        "handoffChecklist",
        "estimatedImpact",
        "markdown"
      ]
    }
  },
  "marketplace.dealsniper": {
    "purpose": "Analyze marketplace listings and return a structured deal assessment.",
    "input_type": "marketplace_listing",
    "output_type": "deal_analysis",
    "preferred_worker_type": "default_worker",
    "fallback_behavior": "fail_when_runtime_unavailable",
    "validation_expectations": {
      "output_schema": null,
      "verification_step": "validate_analysis",
      "required_result_sections": ["summary", "dealScore", "meta"]
    }
  },
  "publishing.operator_log_discovery": {
    "purpose": "Inventory the allowlisted Second Brain and rank source-linked Operator Log opportunities.",
    "input_type": "editorial_discovery_request",
    "output_type": "editorial_opportunity_report",
    "preferred_worker_type": "reasoning_worker",
    "fallback_behavior": "fail_when_runtime_or_memory_unavailable",
    "validation_expectations": {
      "output_schema": "companion/schemas/editorial-opportunity-report.schema.json",
      "verification_step": "verify_report",
      "required_result_sections": ["summary", "recommendedOpportunity", "opportunities"]
    }
  },
  "publishing.operator_log_draft": {
    "purpose": "Turn a selected evidence-backed opportunity into reviewable Operator Log HTML and sitemap proposals.",
    "input_type": "selected_editorial_opportunity",
    "output_type": "operator_log_html_proposal",
    "preferred_worker_type": "default_worker",
    "fallback_behavior": "fail_when_runtime_unavailable",
    "validation_expectations": {
      "output_schema": "companion/schemas/operator-log-draft.schema.json",
      "verification_step": "verify_draft",
      "required_result_sections": ["headline", "slug", "html", "sitemapEntry"]
    }
  }
}
