{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://locaily.local/schemas/track-run-record.schema.json",
  "title": "Canonical Track Run Record",
  "description": "Standardized execution record for every Track run, regardless of executor type. Used by Benchmark Lab and runtime executions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "recordId",
    "trackId",
    "routing",
    "execution",
    "timestamps"
  ],
  "properties": {
    "schemaVersion": {
      "const": "locaily.track_run_record.v1",
      "description": "Canonical record schema version."
    },
    "recordId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for this execution record."
    },
    "trackId": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the Track that was executed."
    },
    "workflowId": {
      "type": "string",
      "description": "Workflow identifier when the Track ran as part of a workflow."
    },
    "parentRunId": {
      "type": "string",
      "description": "Parent record ID when this is a child run of a hybrid workflow."
    },
    "correlationId": {
      "type": "string",
      "description": "Correlation identifier for grouping related records."
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdAt"
      ],
      "properties": {
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this record was created."
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When execution started."
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When execution completed."
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requester": {
          "type": "string",
          "description": "Component or user that initiated the run."
        },
        "requestedCapability": {
          "type": "string",
          "description": "The capability that was requested."
        },
        "inputSummary": {
          "type": "string",
          "description": "Summary-safe description of input (no raw sensitive data)."
        },
        "inputRef": {
          "type": "string",
          "description": "Reference path or identifier for the full input."
        },
        "constraints": {
          "type": "object",
          "description": "Execution constraints applied to this run.",
          "additionalProperties": true
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executorType"
      ],
      "properties": {
        "executorType": {
          "enum": [
            "model",
            "tool",
            "transform",
            "rule",
            "relay-node",
            "hybrid"
          ],
          "description": "Type of executor that handled this run."
        },
        "capabilityId": {
          "type": "string",
          "description": "Identifier of the selected capability."
        },
        "provider": {
          "type": "string",
          "description": "Runtime provider name (e.g. ollama, mock)."
        },
        "relayNodeId": {
          "type": "string",
          "description": "Relay Node identifier when routing to a remote capability."
        },
        "qualificationRecordId": {
          "type": "string",
          "description": "Identifier of the qualification record that supported the routing decision."
        },
        "routingReason": {
          "type": "string",
          "description": "Why this capability was selected for this run."
        },
        "fallbackCandidates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative capabilities considered as fallbacks."
        },
        "shadowRecommendation": {
          "type": "object",
          "additionalProperties": false,
          "description": "Shadow-mode qualification routing recommendation for comparison. Not enforced.",
          "properties": {
            "enabled": { "type": "boolean" },
            "enforced": { "type": "boolean", "const": false },
            "selectedCapabilityId": { "type": "string" },
            "recommendedCapabilityId": { "type": "string" },
            "recommendedRuntimeModelName": { "type": "string" },
            "recommendedScore": { "type": "number" },
            "state": { "type": "string" },
            "selectedQualificationState": { "type": "string", "description": "Qualification state of the currently selected capability" },
            "recommendedQualificationState": { "type": "string", "description": "Qualification state of the recommended capability" },
            "comparison": {
              "enum": [
                "agree",
                "disagree",
                "no-qualified-capability",
                "insufficient-evidence",
                "current-selection-unqualified",
                "recommendation-unavailable"
              ]
            },
            "reason": { "type": "string" },
            "notEnforcedReason": { "type": "string" },
            "qualificationRecordId": { "type": "string" },
            "fallbackRecommendation": { "type": "string" }
          }
        },
        "enforcementDecision": {
          "type": "object",
          "additionalProperties": false,
          "description": "Guarded qualification-aware enforcement decision. Present only when enforcement was evaluated.",
          "properties": {
            "state": {
              "type": "string",
              "description": "Enforcement state at time of decision"
            },
            "eligible": {
              "type": "boolean",
              "description": "Whether the recommendation was eligible"
            },
            "attempted": {
              "type": "boolean",
              "description": "Whether enforcement was attempted"
            },
            "applied": {
              "type": "boolean",
              "description": "Whether enforcement was applied"
            },
            "reason": {
              "type": "string",
              "description": "Human-readable reason for the decision"
            },
            "failedConditions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "condition": { "type": "string" },
                  "detail": { "type": "string" }
                }
              },
              "description": "Conditions that prevented enforcement"
            },
            "checks": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              },
              "description": "Policy checks evaluated during enforcement"
            },
            "overrideApplied": {
              "type": "boolean",
              "description": "Whether an override blocked enforcement"
            },
            "fallbackCapabilityId": {
              "type": "string",
              "description": "Capability used as fallback"
            },
            "fallbackTriggered": {
              "type": "boolean",
              "description": "Whether fallback execution occurred"
            },
            "fallbackSucceeded": {
              "type": "boolean",
              "description": "Whether fallback execution succeeded"
            },
            "originalError": {
              "type": "object",
              "additionalProperties": false,
              "description": "Original error when enforced execution failed",
              "properties": {
                "message": { "type": "string" },
                "code": { "type": "string" }
              }
            },
            "selectedCapabilityId": {
              "type": "string",
              "description": "Original capability selected before enforcement"
            },
            "selectedQualificationState": {
              "type": "string",
              "description": "Qualification state of the selected capability at time of enforcement evaluation"
            },
            "recommendedCapabilityId": {
              "type": "string",
              "description": "Capability recommended by qualification"
            },
            "recommendedQualificationState": {
              "type": "string",
              "description": "Qualification state of the recommended capability at time of enforcement evaluation"
            },
            "executedCapabilityId": {
              "type": "string",
              "description": "Final capability that executed"
            },
            "qualificationRecordId": {
              "type": "string",
              "description": "Qualification record that supported the recommendation"
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "success",
            "failure",
            "partial",
            "timeout",
            "error",
            "skipped"
          ],
          "description": "Overall execution status."
        },
        "durationMs": {
          "type": "number",
          "minimum": 0,
          "description": "Total execution duration in milliseconds."
        },
        "retryCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries attempted."
        },
        "fallbackUsed": {
          "type": "boolean",
          "description": "Whether a fallback executor was used."
        },
        "modelInfo": {
          "type": "object",
          "description": "Executor-specific metadata for model-type runs.",
          "additionalProperties": true,
          "properties": {
            "modelId": { "type": "string" },
            "runtimeModelName": { "type": "string" },
            "temperature": { "type": "number" },
            "numPredict": { "type": "integer" },
            "role": { "type": "string" }
          }
        },
        "toolInfo": {
          "type": "object",
          "description": "Executor-specific metadata for tool-type runs.",
          "additionalProperties": true,
          "properties": {
            "toolId": { "type": "string" },
            "task": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "transformInfo": {
          "type": "object",
          "description": "Executor-specific metadata for transform-type runs.",
          "additionalProperties": true,
          "properties": {
            "transformerId": { "type": "string" },
            "version": { "type": "string" },
            "checksum": { "type": "string" },
            "inputValid": { "type": "boolean" },
            "outputValid": { "type": "boolean" },
            "sourceFaithful": { "type": "boolean" }
          }
        },
        "ruleInfo": {
          "type": "object",
          "description": "Executor-specific metadata for rule-type runs.",
          "additionalProperties": true,
          "properties": {
            "ruleId": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "relayNodeInfo": {
          "type": "object",
          "description": "Executor-specific metadata for relay-node-type runs.",
          "additionalProperties": true,
          "properties": {
            "nodeId": { "type": "string" },
            "capability": { "type": "string" },
            "remoteDurationMs": { "type": "number" }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outputFormat": {
          "type": "string",
          "description": "Format of the output (e.g. json, markdown, text)."
        },
        "outputSummary": {
          "type": "string",
          "description": "Summary-safe description of output."
        },
        "outputRef": {
          "type": "string",
          "description": "Reference path or identifier for the full output."
        },
        "structuredOutputValid": {
          "type": "boolean",
          "description": "Whether the output matched the expected schema."
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "path": { "type": "string" },
              "type": { "type": "string" },
              "checksum": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "Generated artifacts or evidence files."
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "References to promoted evidence records."
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "enum": [
            "passed",
            "failed",
            "partial",
            "not_validated"
          ],
          "description": "Overall validation status."
        },
        "validatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Identifiers of validators that were applied."
        },
        "failedChecks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "validator": { "type": "string" },
              "message": { "type": "string" }
            }
          },
          "description": "Checks that failed during validation."
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Warnings produced during validation."
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Validation score or confidence between 0 and 1."
        }
      }
    },
    "performance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalDurationMs": {
          "type": "number",
          "minimum": 0,
          "description": "Total wall-clock duration in milliseconds."
        },
        "modelLoadTimeMs": {
          "type": "number",
          "minimum": 0,
          "description": "Model loading time where applicable."
        },
        "inferenceTimeMs": {
          "type": "number",
          "minimum": 0,
          "description": "Model inference time where applicable."
        },
        "toolExecutionTimeMs": {
          "type": "number",
          "minimum": 0,
          "description": "Tool execution time where applicable."
        },
        "tokenCounts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "prompt": { "type": "integer", "minimum": 0 },
            "completion": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          },
          "description": "Token counts when available from the runtime."
        },
        "ramVramMetrics": {
          "type": "object",
          "additionalProperties": true,
          "description": "Memory utilization metrics when available."
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Normalized error type code."
        },
        "source": {
          "type": "string",
          "description": "Component that produced the error."
        },
        "recoverable": {
          "type": "boolean",
          "description": "Whether the error is potentially recoverable."
        },
        "fallbackResult": {
          "type": "string",
          "description": "Summary of the fallback result if one was used."
        },
        "diagnosticSummary": {
          "type": "string",
          "description": "Safe diagnostic details about the error."
        }
      }
    },
    "childRuns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "recordId",
          "trackId",
          "routing",
          "execution",
          "timestamps"
        ],
        "properties": {
          "schemaVersion": {
            "const": "locaily.track_run_record.v1"
          },
          "recordId": {
            "type": "string",
            "minLength": 1
          },
          "trackId": {
            "type": "string",
            "minLength": 1
          },
          "workflowId": {
            "type": "string"
          },
          "parentRunId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "timestamps": {
            "type": "object",
            "additionalProperties": false,
            "required": ["createdAt"],
            "properties": {
              "createdAt": { "type": "string", "format": "date-time" },
              "startedAt": { "type": "string", "format": "date-time" },
              "completedAt": { "type": "string", "format": "date-time" }
            }
          },
          "request": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "requester": { "type": "string" },
              "requestedCapability": { "type": "string" },
              "inputSummary": { "type": "string" },
              "inputRef": { "type": "string" },
              "constraints": { "type": "object", "additionalProperties": true }
            }
          },
          "routing": {
            "type": "object",
            "additionalProperties": false,
            "required": ["executorType"],
            "properties": {
              "executorType": { "enum": ["model", "tool", "transform", "rule", "relay-node", "hybrid"] },
              "capabilityId": { "type": "string" },
              "provider": { "type": "string" },
              "relayNodeId": { "type": "string" },
              "qualificationRecordId": { "type": "string" },
              "routingReason": { "type": "string" },
              "fallbackCandidates": { "type": "array", "items": { "type": "string" } },
              "shadowRecommendation": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean" },
                  "enforced": { "type": "boolean", "const": false },
                  "selectedCapabilityId": { "type": "string" },
                  "recommendedCapabilityId": { "type": "string" },
                  "recommendedRuntimeModelName": { "type": "string" },
                  "recommendedScore": { "type": "number" },
                  "state": { "type": "string" },
                  "selectedQualificationState": { "type": "string" },
                  "recommendedQualificationState": { "type": "string" },
                  "comparison": { "enum": ["agree", "disagree", "no-qualified-capability", "insufficient-evidence", "current-selection-unqualified", "recommendation-unavailable"] },
                  "reason": { "type": "string" },
                  "notEnforcedReason": { "type": "string" },
                  "qualificationRecordId": { "type": "string" },
                  "fallbackRecommendation": { "type": "string" }
                }
              },
              "enforcementDecision": {
                "type": "object",
                "additionalProperties": false,
                "description": "Guarded qualification-aware enforcement decision.",
                "properties": {
                  "state": { "type": "string" },
                  "eligible": { "type": "boolean" },
                  "attempted": { "type": "boolean" },
                  "applied": { "type": "boolean" },
                  "reason": { "type": "string" },
                  "failedConditions": { "type": "array", "items": { "type": "object", "additionalProperties": false, "properties": { "condition": { "type": "string" }, "detail": { "type": "string" } } } },
                  "checks": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                  "overrideApplied": { "type": "boolean" },
                  "fallbackCapabilityId": { "type": "string" },
                  "fallbackTriggered": { "type": "boolean" },
                  "fallbackSucceeded": { "type": "boolean" },
                  "originalError": { "type": "object", "additionalProperties": false, "properties": { "message": { "type": "string" }, "code": { "type": "string" } } },
                  "selectedCapabilityId": { "type": "string" },
                  "selectedQualificationState": { "type": "string" },
                  "recommendedCapabilityId": { "type": "string" },
                  "recommendedQualificationState": { "type": "string" },
                  "executedCapabilityId": { "type": "string" },
                  "qualificationRecordId": { "type": "string" }
                }
              }
            }
          },
          "execution": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status"],
            "properties": {
              "status": { "enum": ["success", "failure", "partial", "timeout", "error", "skipped"] },
              "durationMs": { "type": "number", "minimum": 0 },
              "retryCount": { "type": "integer", "minimum": 0 },
              "fallbackUsed": { "type": "boolean" },
              "modelInfo": { "type": "object", "additionalProperties": true, "properties": { "modelId": { "type": "string" }, "runtimeModelName": { "type": "string" }, "temperature": { "type": "number" }, "numPredict": { "type": "integer" }, "role": { "type": "string" } } },
              "toolInfo": { "type": "object", "additionalProperties": true, "properties": { "toolId": { "type": "string" }, "task": { "type": "string" }, "version": { "type": "string" } } },
              "transformInfo": { "type": "object", "additionalProperties": true, "properties": { "transformerId": { "type": "string" }, "version": { "type": "string" }, "checksum": { "type": "string" }, "inputValid": { "type": "boolean" }, "outputValid": { "type": "boolean" }, "sourceFaithful": { "type": "boolean" } } },
              "ruleInfo": { "type": "object", "additionalProperties": true, "properties": { "ruleId": { "type": "string" }, "version": { "type": "string" } } },
              "relayNodeInfo": { "type": "object", "additionalProperties": true, "properties": { "nodeId": { "type": "string" }, "capability": { "type": "string" }, "remoteDurationMs": { "type": "number" } } }
            }
          },
          "output": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "outputFormat": { "type": "string" },
              "outputSummary": { "type": "string" },
              "outputRef": { "type": "string" },
              "structuredOutputValid": { "type": "boolean" },
              "artifacts": { "type": "array", "items": { "type": "object", "additionalProperties": false, "properties": { "path": { "type": "string" }, "type": { "type": "string" }, "checksum": { "type": "string" }, "description": { "type": "string" } } } },
              "evidenceRefs": { "type": "array", "items": { "type": "string" } }
            }
          },
          "validation": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status": { "enum": ["passed", "failed", "partial", "not_validated"] },
              "validatorIds": { "type": "array", "items": { "type": "string" } },
              "failedChecks": { "type": "array", "items": { "type": "object", "additionalProperties": false, "properties": { "validator": { "type": "string" }, "message": { "type": "string" } } } },
              "warnings": { "type": "array", "items": { "type": "string" } },
              "score": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "performance": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "totalDurationMs": { "type": "number", "minimum": 0 },
              "modelLoadTimeMs": { "type": "number", "minimum": 0 },
              "inferenceTimeMs": { "type": "number", "minimum": 0 },
              "toolExecutionTimeMs": { "type": "number", "minimum": 0 },
              "tokenCounts": { "type": "object", "additionalProperties": false, "properties": { "prompt": { "type": "integer", "minimum": 0 }, "completion": { "type": "integer", "minimum": 0 }, "total": { "type": "integer", "minimum": 0 } } },
              "ramVramMetrics": { "type": "object", "additionalProperties": true }
            }
          },
          "error": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string" },
              "source": { "type": "string" },
              "recoverable": { "type": "boolean" },
              "fallbackResult": { "type": "string" },
              "diagnosticSummary": { "type": "string" }
            }
          }
        }
      },
      "description": "Child execution records for hybrid workflows."
    }
  }
}
