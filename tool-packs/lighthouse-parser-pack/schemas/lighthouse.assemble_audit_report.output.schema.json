          "title": { "type": "string" },
          "severity": { "type": "string" },
          "finding": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "reportMarkdown": { "type": "string" }
  }
