{
  "id": "lighthouse-parser-pack",
  "name": "Lighthouse Parser Pack",
  "version": "0.1.0",
  "trust": "official",
  "permissions": [],
  "tools": [
    {
      "id": "lighthouse.parse",
      "description": "Deterministically extract Lighthouse metrics from report input.",
      "model_role": null,
      "permissions": [],
      "input_schema": "schemas/lighthouse.parse.input.schema.json",
      "output_schema": "schemas/lighthouse.parse.output.schema.json"
    },
    {
      "id": "lighthouse.classify_audits",
      "description": "Deterministically classify Lighthouse audits by id and score.",
      "model_role": null,
      "permissions": [],
      "input_schema": "schemas/lighthouse.classify_audits.input.schema.json",
      "output_schema": "schemas/lighthouse.classify_audits.output.schema.json"
    },
    {
      "id": "lighthouse.validate_priority_fixes",
      "description": "Validate model priority fixes against measured Lighthouse audit data.",
      "model_role": null,
      "permissions": [],
      "input_schema": "schemas/lighthouse.validate_priority_fixes.input.schema.json",
      "output_schema": "schemas/lighthouse.validate_priority_fixes.output.schema.json"
    },
    {
      "id": "lighthouse.match_fixes",
      "description": "Match prioritized Lighthouse issues to suggested fix steps.",
      "model_role": null,
      "permissions": [],
      "input_schema": "schemas/lighthouse.match_fixes.input.schema.json",
      "output_schema": "schemas/lighthouse.match_fixes.output.schema.json"
    },
    {
      "id": "lighthouse.verify_handoff",
      "description": "Validate Lighthouse handoff output structure.",
      "model_role": null,
